---
const year = new Date().getFullYear();
---

<footer class="mt-auto border-t" style="background-color: var(--color-header-bg); color: var(--color-text-secondary); border-color: var(--color-border);">
  <div class="max-w-6xl mx-auto px-4 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- About -->
      <div>
        <div class="flex items-center gap-2 mb-3">
          <img src="/logo-noi.jpg" alt="Logo NOI" class="w-8 h-8 rounded-full object-cover" />
          <h3 class="font-bold text-lg" style="color: var(--color-primary);">Associazione NOI</h3>
        </div>
        <p class="text-sm leading-relaxed" style="color: var(--color-text-muted);">
          Circolo di promozione sociale e culturale di Noventa di Piave.
          Attività, eventi e manifestazioni per la comunità.
        </p>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="font-bold text-lg mb-3" style="color: var(--color-secondary);">Contatti</h3>
        <ul class="text-sm space-y-2">
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 mt-0.5 shrink-0" style="color: var(--color-primary);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>Via Martiri della Libertà 118/120<br/>30027 Noventa di Piave (VE)</span>
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 shrink-0" style="color: var(--color-primary);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <a href="mailto:noicircolo@gmail.com" class="hover:underline" style="color: var(--color-primary);">noicircolo@gmail.com</a>
          </li>
        </ul>
      </div>

      <!-- Links -->
      <div>
        <h3 class="font-bold text-lg mb-3" style="color: var(--color-secondary);">Link utili</h3>
        <ul class="text-sm space-y-2">
          <li><a href="https://www.facebook.com/people/NOI-Circolo-San-Luigi-APS-Noventa-di-Piave/100093341352626/" target="_blank" rel="noopener" class="hover:underline" style="color: var(--color-primary);">Facebook</a></li>
          <li><a href="/notizie" class="hover:underline" style="color: var(--color-primary);">Ultime notizie</a></li>
          <li><a href="/galleria" class="hover:underline" style="color: var(--color-primary);">Galleria fotografica</a></li>
        </ul>
      </div>
    </div>

    <div class="border-t mt-8 pt-6 text-center text-xs" style="color: var(--color-text-muted); border-color: var(--color-border);">
      &copy; {year} Associazione NOI — Noventa di Piave. Tutti i diritti riservati.
    </div>
  </div>
</footer>
