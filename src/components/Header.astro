---
const navItems = [
  { href: "/", label: "Home" },
  { href: "/dove-siamo", label: "Dove siamo" },
  { href: "/notizie", label: "Notizie" },
  { href: "/galleria", label: "Galleria" },
];

const currentPath = Astro.url.pathname;
---

<header class="bg-black text-white shadow-lg sticky top-0 z-50">
  <div class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between">
    <a href="/" class="flex items-center gap-3 hover:opacity-90 transition-opacity">
      <img src="/favicon.svg" alt="Logo NOI" class="w-10 h-10" />
      <div class="hidden sm:block">
        <div class="font-bold text-lg leading-tight text-[#00AEEF]">Associazione NOI</div>
        <div class="text-gray-400 text-xs">Noventa di Piave</div>
      </div>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-1">
      {navItems.map((item) => (
        <a
          href={item.href}
          class:list={[
            "px-4 py-2 rounded-lg text-sm font-medium transition-colors",
            currentPath === item.href || (item.href !== "/" && currentPath.startsWith(item.href))
              ? "bg-[#00AEEF] text-black"
              : "text-gray-300 hover:bg-white/10 hover:text-white",
          ]}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <!-- Mobile hamburger -->
    <button
      id="menu-toggle"
      class="md:hidden p-2 rounded-lg hover:bg-white/10 transition-colors"
      aria-label="Menu"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>

  <!-- Mobile nav -->
  <nav id="mobile-menu" class="hidden md:hidden bg-gray-900 border-t border-gray-800">
    <div class="max-w-6xl mx-auto px-4 py-2">
      {navItems.map((item) => (
        <a
          href={item.href}
          class:list={[
            "block px-4 py-3 rounded-lg text-sm font-medium transition-colors",
            currentPath === item.href || (item.href !== "/" && currentPath.startsWith(item.href))
              ? "bg-[#00AEEF] text-black"
              : "text-gray-300 hover:bg-white/10 hover:text-white",
          ]}
        >
          {item.label}
        </a>
      ))}
    </div>
  </nav>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
