---
import ThemeToggle from './ThemeToggle.astro';

const navItems = [
  { href: "/", label: "Home" },
  { href: "/dove-siamo", label: "Dove siamo" },
  { href: "/notizie", label: "Notizie" },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 shadow-lg" style="background-color: var(--color-header-bg); color: var(--color-header-text); border-bottom: 1px solid var(--color-border);">
  <div class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between">
    <a href="/" class="flex items-center gap-3 hover:opacity-90 transition-opacity">
      <img src="/logo-noi.jpg" alt="Logo NOI" class="w-10 h-10 rounded-full object-cover" />
      <div class="hidden sm:block">
        <div class="font-bold text-lg leading-tight" style="color: var(--color-primary);">Associazione NOI</div>
        <div class="text-xs" style="color: var(--color-text-muted);">Noventa di Piave</div>
      </div>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-1">
      {navItems.map((item) => (
        <a
          href={item.href}
          class:list={[
            "px-4 py-2 rounded-lg text-sm font-medium transition-colors hover:bg-gray-100 dark:hover:bg-white/10",
            currentPath === item.href || (item.href !== "/" && currentPath.startsWith(item.href))
              ? ""
              : "",
          ]}
          style={currentPath === item.href || (item.href !== "/" && currentPath.startsWith(item.href))
            ? `background-color: var(--color-primary); color: #000;`
            : `color: var(--color-text-secondary);`
          }
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-1">
      <ThemeToggle />
      <!-- Mobile hamburger -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 rounded-lg hover:bg-gray-100 dark:hover:bg-white/10 transition-colors"
        style="color: var(--color-text);"
        aria-label="Apri menu"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile nav -->
  <nav id="mobile-menu" class="hidden md:hidden border-t" style="background-color: var(--color-bg); border-color: var(--color-border);">
    <div class="max-w-6xl mx-auto px-4 py-2">
      {navItems.map((item) => (
        <a
          href={item.href}
          class:list={[
            "block px-4 py-3 rounded-lg text-sm font-medium transition-colors",
            currentPath === item.href || (item.href !== "/" && currentPath.startsWith(item.href))
              ? "font-bold"
              : "",
          ]}
          style={currentPath === item.href || (item.href !== "/" && currentPath.startsWith(item.href))
            ? `background-color: var(--color-primary); color: #000;`
            : `color: var(--color-text-secondary);`
          }
        >
          {item.label}
        </a>
      ))}
    </div>
  </nav>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');

  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
