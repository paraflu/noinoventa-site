---
import BaseLayout from '../layouts/BaseLayout.astro';

const news = [
  {
    title: "Notte di fiabe al Parco – ECCO I MOSTRI!",
    date: "18 Giu 2026",
    image: "https://www.noinoventa.it/joomla/images/fiabe_parco_web.jpg",
    excerpt: "Porta un telo mare o una coperta e accomodati sul prato: lo spettacolo è sotto le stelle!",
    slug: "notte-di-fiabe-al-parco",
  },
  {
    title: "Sagra dell'Uva 2026 – Programma Completo",
    date: "15 Giu 2026",
    image: "https://www.noinoventa.it/images/Programma_Sagra_2026-1.jpg",
    excerpt: "Ecco il programma completo della Sagra dell'Uva 2026. Tante iniziative, gusti e tradizione!",
    slug: "sagra-uva-2026",
  },
  {
    title: "Intrecciamo Storie – Laboratorio di Scrittura Creativa",
    date: "10 Giu 2026",
    image: "https://www.noinoventa.it/images/intrecciamostorie.png",
    excerpt: "Un percorso di scrittura creativa aperto a tutti. Le storie si intrecciano tra loro.",
    slug: "intrecciamo-storie",
  },
];
---

<BaseLayout title="Home">
  <!-- Hero -->
  <section class="text-white" style="background: linear-gradient(135deg, var(--color-hero-from), var(--color-hero-via), var(--color-hero-to));">
    <div class="max-w-6xl mx-auto px-4 py-20 md:py-28 text-center">
      <div class="flex justify-center mb-6">
        <img src="/logo-noi.jpg" alt="Logo NOI" class="w-24 h-24 rounded-full object-cover" />
      </div>
      <h1 class="text-4xl md:text-5xl font-bold mb-4">
        Associazione <span style="color: var(--color-secondary);">NOI</span>
      </h1>
      <p class="text-xl md:text-2xl mb-8 max-w-2xl mx-auto" style="color: var(--color-text-secondary);">
        Noventa di Piave — Circolo di promozione sociale e culturale
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/notizie"
          class="px-8 py-3 rounded-lg font-bold transition-colors text-black"
          style="background-color: var(--color-primary);"
        >
          Ultime Notizie
        </a>
        <a
          href="/dove-siamo"
          class="border-2 px-8 py-3 rounded-lg font-medium transition-colors"
          style="border-color: var(--color-secondary); color: var(--color-secondary);"
        >
          Dove Siamo
        </a>
      </div>
    </div>
  </section>

  <!-- News preview -->
  <section class="max-w-6xl mx-auto px-4 py-16" style="background-color: var(--color-bg-secondary);">
    <div class="flex items-center justify-between mb-8">
      <h2 class="text-3xl font-bold" style="color: var(--color-text);">Ultime Notizie</h2>
      <a href="/notizie" class="font-medium text-sm" style="color: var(--color-primary);">
        Vedi tutte →
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {news.map((item) => (
        <article class="rounded-xl shadow-md overflow-hidden hover:shadow-lg transition-shadow border" style="background-color: var(--color-bg-card); border-color: var(--color-border);">
          <div class="aspect-[3/4] overflow-hidden">
            <img
              src={item.image}
              alt={item.title}
              class="w-full h-full object-cover hover:scale-105 transition-transform duration-300"
              loading="lazy"
            />
          </div>
          <div class="p-5">
            <time class="text-xs font-medium" style="color: var(--color-text-muted);">{item.date}</time>
            <h3 class="text-lg font-bold mt-1 mb-2 line-clamp-2" style="color: var(--color-text);">{item.title}</h3>
            <p class="text-sm line-clamp-2" style="color: var(--color-text-secondary);">{item.excerpt}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- About strip -->
  <section class="border-y" style="background-color: var(--color-bg); border-color: var(--color-border);">
    <div class="max-w-6xl mx-auto px-4 py-16 text-center">
      <h2 class="text-3xl font-bold mb-4" style="color: var(--color-text);">Il nostro circolo</h2>
      <p class="max-w-2xl mx-auto leading-relaxed" style="color: var(--color-text-secondary);">
        L'Associazione NOI è un circolo di promozione sociale e culturale di Noventa di Piave.
        Organizziamo eventi, rassegne teatrali, sagre, laboratori e attività per tutta la comunità.
      </p>
    </div>
  </section>
</BaseLayout>
