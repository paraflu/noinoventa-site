---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Dove siamo">
  <!-- Hero -->
  <section class="text-white" style="background: linear-gradient(135deg, var(--color-hero-from), var(--color-hero-via), var(--color-hero-to));">
    <div class="max-w-6xl mx-auto px-4 py-16 text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">Dove siamo</h1>
      <p class="text-xl" style="color: var(--color-text-secondary);">Vieni a trovarci a Noventa di Piave</p>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-4 py-16" style="background-color: var(--color-bg-secondary);">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
      <!-- Info -->
      <div>
        <h2 class="text-2xl font-bold mb-6" style="color: var(--color-text);">Associazione NOI</h2>

        <div class="space-y-6">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-lg flex items-center justify-center shrink-0" style="background-color: color-mix(in srgb, var(--color-primary) 20%, transparent);">
              <svg class="w-5 h-5" style="color: var(--color-primary);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <div>
              <h3 class="font-bold" style="color: var(--color-text);">Indirizzo</h3>
              <p style="color: var(--color-text-secondary);">Via Martiri della Libertà 118/120<br/>30027 Noventa di Piave (VE)</p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-lg flex items-center justify-center shrink-0" style="background-color: color-mix(in srgb, var(--color-primary) 20%, transparent);">
              <svg class="w-5 h-5" style="color: var(--color-primary);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <div>
              <h3 class="font-bold" style="color: var(--color-text);">Email</h3>
              <a href="mailto:noicircolo@gmail.com" class="hover:underline" style="color: var(--color-primary);">noicircolo@gmail.com</a>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-lg flex items-center justify-center shrink-0" style="background-color: color-mix(in srgb, var(--color-primary) 20%, transparent);">
              <svg class="w-5 h-5" style="color: var(--color-primary);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </div>
            <div>
              <h3 class="font-bold" style="color: var(--color-text);">Telefono</h3>
              <p style="color: var(--color-text-secondary);">338 7040775 / 347 1886094</p>
            </div>
          </div>
        </div>

        <div class="mt-8">
          <a
            href="https://www.facebook.com/people/NOI-Circolo-San-Luigi-APS-Noventa-di-Piave/100093341352626/"
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-2 px-6 py-3 rounded-lg font-medium transition-colors text-black"
            style="background-color: var(--color-primary);"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
            Seguici su Facebook
          </a>
        </div>
      </div>

      <!-- Map -->
      <div class="rounded-xl overflow-hidden shadow-lg border h-96 md:h-auto min-h-[400px]" style="border-color: var(--color-border);">
        <iframe
          src="https://www.openstreetmap.org/export/embed.html?bbox=12.5300%2C45.6650%2C12.5400%2C45.6750&amp;layer=mapnik&amp;marker=45.6700%2C12.5350"
          width="100%"
          height="100%"
          style="border:0;"
          allowfullscreen
          loading="lazy"
          title="Mappa - Via Martiri della Libertà, Noventa di Piave"
        ></iframe>
      </div>
    </div>
  </section>
</BaseLayout>
