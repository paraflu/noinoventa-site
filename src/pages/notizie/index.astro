---
import BaseLayout from '../../layouts/BaseLayout.astro';

const news = [
  {
    title: "Notte di fiabe al Parco – ECCO I MOSTRI!",
    date: "18 Giu 2026",
    author: "Andrea Forlin",
    image: "https://www.noinoventa.it/joomla/images/fiabe_parco_web.jpg",
    content: "NOTTE DI FIABE AL PARCO — ECCO I MOSTRI!\n\nPorta un telo mare o una coperta e accomodati sul prato: lo spettacolo è sotto le stelle!\n\nPer info: 338 7040775 / 347 1886094",
    category: "Eventi",
    slug: "notte-di-fiabe-al-parco",
  },
  {
    title: "Sagra dell'Uva 2026 – Programma Completo",
    date: "15 Giu 2026",
    author: "Andrea Forlin",
    image: "https://www.noinoventa.it/images/Programma_Sagra_2026-1.jpg",
    content: "Ecco il programma completo della Sagra dell'Uva 2026. Tante iniziative, gusti e tradizione!",
    category: "Sagre",
    slug: "sagra-uva-2026",
  },
  {
    title: "Intrecciamo Storie – Laboratorio di Scrittura Creativa",
    date: "10 Giu 2026",
    author: "Andrea Forlin",
    image: "https://www.noinoventa.it/images/intrecciamostorie.png",
    content: "Un percorso di scrittura creativa aperto a tutti. Le storie si intrecciano tra loro.",
    category: "Laboratori",
    slug: "intrecciamo-storie",
  },
  {
    title: "Musica del Cuore – Concerto di Beneficenza",
    date: "5 Giu 2026",
    author: "Andrea Forlin",
    image: "https://www.noinoventa.it/images/musica-del-cuore.jpeg",
    content: "Un concerto speciale per raccogliere fondi. La musica che unisce le persone.",
    category: "Concerti",
    slug: "musica-del-cuore",
  },
  {
    title: "Festa della Repubblica – Programma degli Eventi",
    date: "2 Giu 2026",
    author: "Andrea Forlin",
    image: "https://www.noinoventa.it/images/photo_5809658509203803762_y.jpg",
    content: "Programma degli eventi per la Festa della Repubblica a Noventa di Piave.",
    category: "Eventi",
    slug: "festa-repubblica",
  },
];

const categories = ["Tutti", ...new Set(news.map(n => n.category))];
---

<BaseLayout title="Notizie">
  <!-- Hero -->
  <section class="text-white" style="background: linear-gradient(135deg, var(--color-hero-from), var(--color-hero-via), var(--color-hero-to));">
    <div class="max-w-6xl mx-auto px-4 py-16 text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">Notizie</h1>
      <p class="text-xl" style="color: var(--color-text-secondary);">Tutto ciò che accade nel nostro circolo</p>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-4 py-12" style="background-color: var(--color-bg-secondary);">
    <!-- Category filters -->
    <div class="flex flex-wrap gap-2 mb-10">
      {categories.map((cat) => (
        <button
          class="px-4 py-2 rounded-full text-sm font-medium transition-colors border"
          data-category={cat}
          style={cat === "Tutti"
            ? `background-color: var(--color-primary); color: #000; border-color: var(--color-primary);`
            : `background-color: var(--color-bg-card); color: var(--color-text-secondary); border-color: var(--color-border);`
          }
        >
          {cat}
        </button>
      ))}
    </div>

    <!-- News list -->
    <div class="space-y-8">
      {news.map((item) => (
        <article class="rounded-xl shadow-md overflow-hidden border transition-colors" style="background-color: var(--color-bg-card); border-color: var(--color-border);">
          <div class="md:flex">
            <div class="md:w-72 shrink-0">
              <img
                src={item.image}
                alt={item.title}
                class="w-full h-48 md:h-full object-cover"
                loading="lazy"
              />
            </div>
            <div class="p-6 flex flex-col justify-center">
              <div class="flex items-center gap-3 mb-2">
                <span class="text-xs font-medium px-2.5 py-0.5 rounded-full" style="background-color: color-mix(in srgb, var(--color-primary) 20%, transparent); color: var(--color-primary);">{item.category}</span>
                <time class="text-xs" style="color: var(--color-text-muted);">{item.date}</time>
              </div>
              <h2 class="text-xl font-bold mb-2" style="color: var(--color-text);">{item.title}</h2>
              <p class="text-sm leading-relaxed mb-3" style="color: var(--color-text-secondary);">{item.content}</p>
              <div class="text-xs" style="color: var(--color-text-muted);">di {item.author}</div>
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
