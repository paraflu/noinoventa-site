---
import BaseLayout from '../../layouts/BaseLayout.astro';

const galleries = [
  {
    title: "120 anni di Storia",
    description: "Un viaggio nella storia del nostro circolo",
    cover: "https://www.noinoventa.it/images/intrecciamostorie.png",
    count: 45,
  },
  {
    title: "Anni 1960",
    description: "Gli anni della fondazione",
    cover: "https://www.noinoventa.it/images/musica-del-cuore.jpeg",
    count: 32,
  },
  {
    title: "Anni 1970",
    description: "Il decennio dell'espansione",
    cover: "https://www.noinoventa.it/images/Programma_Sagra_2026-1.jpg",
    count: 28,
  },
  {
    title: "Anni 1980",
    description: "Gli anni '80 del circolo",
    cover: "https://www.noinoventa.it/images/photo_5809658509203803762_y.jpg",
    count: 35,
  },
  {
    title: "Sagre e Feste",
    description: "Le manifestazioni più importanti",
    cover: "https://www.noinoventa.it/images/Programma_Sagra_2026-1.jpg",
    count: 50,
  },
  {
    title: "Eventi Recenti",
    description: "Gli ultimi eventi del circolo",
    cover: "https://www.noinoventa.it/joomla/images/fiabe_parco_web.jpg",
    count: 22,
  },
];
---

<BaseLayout title="Galleria">
  <!-- Hero -->
  <section class="text-white" style="background: linear-gradient(135deg, var(--color-hero-from), var(--color-hero-via), var(--color-hero-to));">
    <div class="max-w-6xl mx-auto px-4 py-16 text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">Galleria</h1>
      <p class="text-xl" style="color: var(--color-text-secondary);">Ricordi e momenti del nostro circolo</p>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-4 py-12" style="background-color: var(--color-bg-secondary);">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {galleries.map((gallery) => (
        <div class="group rounded-xl shadow-md overflow-hidden border transition-all cursor-pointer hover:shadow-lg" style="background-color: var(--color-bg-card); border-color: var(--color-border);">
          <div class="aspect-[4/3] overflow-hidden relative">
            <img
              src={gallery.cover}
              alt={gallery.title}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 to-transparent opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-4">
              <span class="text-sm font-medium" style="color: var(--color-primary);">{gallery.count} foto</span>
            </div>
          </div>
          <div class="p-5">
            <h3 class="font-bold text-lg group-hover:underline" style="color: var(--color-text);">{gallery.title}</h3>
            <p class="text-sm mt-1" style="color: var(--color-text-muted);">{gallery.description}</p>
          </div>
        </div>
      ))}
    </div>

    <p class="text-center text-sm mt-12" style="color: var(--color-text-muted);">
      La galleria completa sarà disponibile al trasferimento dei contenuti dal sito precedente.
    </p>
  </section>
</BaseLayout>
