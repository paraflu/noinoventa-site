---
import BaseLayout from '../../layouts/BaseLayout.astro';

const galleries = [
  {
    title: "120 anni di Storia",
    description: "Un viaggio nella storia del nostro circolo",
    cover: "https://www.noinoventa.it/images/intrecciamostorie.png",
    count: 45,
  },
  {
    title: "Anni 1960",
    description: "Gli anni della fondazione",
    cover: "https://www.noinoventa.it/images/musica-del-cuore.jpeg",
    count: 32,
  },
  {
    title: "Anni 1970",
    description: "Il decennio dell'espansione",
    cover: "https://www.noinoventa.it/images/Programma_Sagra_2026-1.jpg",
    count: 28,
  },
  {
    title: "Anni 1980",
    description: "Gli anni '80 del circolo",
    cover: "https://www.noinoventa.it/images/photo_5809658509203803762_y.jpg",
    count: 35,
  },
  {
    title: "Sagre e Feste",
    description: "Le manifestazioni più importanti",
    cover: "https://www.noinoventa.it/images/Programma_Sagra_2026-1.jpg",
    count: 50,
  },
  {
    title: "Eventi Recenti",
    description: "Gli ultimi eventi del circolo",
    cover: "https://www.noinoventa.it/joomla/images/fiabe_parco_web.jpg",
    count: 22,
  },
];
---

<BaseLayout title="Galleria">
  <!-- Hero -->
  <section class="text-white" style="background: linear-gradient(135deg, var(--color-hero-from), var(--color-hero-via), var(--color-hero-to));">
    <div class="max-w-6xl mx-auto px-4 py-16 text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">Galleria</h1>
      <p class="text-xl" style="color: #94a3b8;">Ricordi e momenti del nostro circolo</p>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-4 py-12">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {galleries.map((gallery) => (
        <div class="rounded-xl overflow-hidden transition-transform hover:scale-[1.02] cursor-pointer" style="background-color: var(--color-bg-card); border: 1px solid var(--color-border);">
          <div class="relative">
            <img src={gallery.cover} alt={gallery.title} class="w-full h-48 object-cover" />
            <div class="absolute inset-0 bg-black/40 flex items-center justify-center opacity-0 hover:opacity-100 transition-opacity">
              <span class="text-white font-semibold">Apri galleria</span>
            </div>
          </div>
          <div class="p-4">
            <h3 class="font-bold" style="color: var(--color-text);">{gallery.title}</h3>
            <p class="text-sm mt-1" style="color: var(--color-text-secondary);">{gallery.description}</p>
            <p class="text-xs mt-2" style="color: var(--color-text-muted);">{gallery.count} foto</p>
          </div>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>
