---
import BaseLayout from '../../layouts/BaseLayout.astro';

const galleries = [
  {
    title: "120 anni di Storia",
    description: "Un viaggio nella storia del nostro circolo",
    cover: "https://www.noinoventa.it/images/intrecciamostorie.png",
    count: 45,
  },
  {
    title: "Anni 1960",
    description: "Gli anni della fondazione",
    cover: "https://www.noinoventa.it/images/musica-del-cuore.jpeg",
    count: 32,
  },
  {
    title: "Anni 1970",
    description: "Il decennio dell'espansione",
    cover: "https://www.noinoventa.it/images/Programma_Sagra_2026-1.jpg",
    count: 28,
  },
  {
    title: "Anni 1980",
    description: "Gli anni '80 del circolo",
    cover: "https://www.noinoventa.it/images/photo_5809658509203803762_y.jpg",
    count: 35,
  },
  {
    title: "Sagre e Feste",
    description: "Le manifestazioni più importanti",
    cover: "https://www.noinoventa.it/images/Programma_Sagra_2026-1.jpg",
    count: 50,
  },
  {
    title: "Eventi Recenti",
    description: "Gli ultimi eventi del circolo",
    cover: "https://www.noinoventa.it/joomla/images/fiabe_parco_web.jpg",
    count: 22,
  },
];
---

<BaseLayout title="Galleria">
  <!-- Hero -->
  <section class="bg-gradient-to-br from-blue-900 to-blue-700 text-white">
    <div class="max-w-6xl mx-auto px-4 py-16 text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">Galleria</h1>
      <p class="text-xl text-blue-100">Ricordi e momenti del nostro circolo</p>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-4 py-12">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {galleries.map((gallery) => (
        <div class="group bg-white rounded-xl shadow-md overflow-hidden border border-gray-100 hover:shadow-lg transition-all cursor-pointer">
          <div class="aspect-[4/3] overflow-hidden relative">
            <img
              src={gallery.cover}
              alt={gallery.title}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-4">
              <span class="text-white text-sm font-medium">{gallery.count} foto</span>
            </div>
          </div>
          <div class="p-5">
            <h3 class="font-bold text-lg text-gray-900 group-hover:text-blue-600 transition-colors">{gallery.title}</h3>
            <p class="text-sm text-gray-500 mt-1">{gallery.description}</p>
          </div>
        </div>
      ))}
    </div>

    <p class="text-center text-gray-400 text-sm mt-12">
      La galleria completa sarà disponibile al trasferimento dei contenuti dal sito precedente.
    </p>
  </section>
</BaseLayout>
